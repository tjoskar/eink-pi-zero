{
  "name": "eink-pi-zero",
  "version": "1.0.0",
  "description": "E-ink display examples using JSX and TypeScript on Raspberry Pi Zero 2.",
  "type": "module",
  "main": "./lib/mod.ts",
  "imports": {
    "#lib": "./lib/mod.ts",
    "#lib/*": "./lib/*.js"
  },
  "scripts": {
    "dev": "MOCK=1 tsx --env-file=.env",
    "dev:watch": "MOCK=1 tsx --env-file=.env --watch",
    "render-once": "MOCK=1 RENDER_ONCE=1 tsx --env-file=.env",
    "build": "esbuild src/*/main.tsx src/*/main.ts --bundle --platform=node --format=esm --outdir=dist --external:@napi-rs/canvas --external:mqtt --external:yoga-layout --sourcemap",
    "start": "node --enable-source-maps dist/hello-world/main.js",
    "deploy": "./scripts/deploy.sh",
    "typecheck": "tsgo --noEmit",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "check": "oxfmt --check && oxlint && tsgo --noEmit",
    "test": "vitest run --project unit --passWithNoTests",
    "test:snapshot": "docker build -t eink-test -f Dockerfile.test . && docker run --rm eink-test",
    "test:snapshot:update": "docker build -t eink-test -f Dockerfile.test . && docker run --rm -e UPDATE_SNAPSHOTS=1 -v ./src:/app/src eink-test"
  },
  "dependencies": {
    "@napi-rs/canvas": "0.1.89",
    "mqtt": "5.14.1",
    "yoga-layout": "3.2.1"
  },
  "devDependencies": {
    "@types/node": "22.0.0",
    "@types/pngjs": "6.0.5",
    "@typescript/native-preview": "7.0.0-dev.20260406.1",
    "esbuild": "0.27.4",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.0",
    "pixelmatch": "7.1.0",
    "pngjs": "7.0.0",
    "tsx": "4.21.0",
    "vitest": "4.1.0"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.28.1"
}
