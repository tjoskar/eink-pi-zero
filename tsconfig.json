{
  "compilerOptions": {
    // Use the classic JSX transform with a custom factory
    "jsx": "react",
    "jsxFactory": "jsx",
    "jsxFragmentFactory": "Fragment",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "esnext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "#lib": ["./lib/mod.ts"]
    }
  },
  "include": ["lib/**/*", "src/**/*"],
  "exclude": ["node_modules"]
}
